# Telegram bot credentials.
# 1. Create a bot with @BotFather (https://t.me/BotFather) and copy its token.
# 2. Message your bot, then open
#    https://api.telegram.org/bot<token>/getUpdates and read "chat":{"id":...}.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: Google Gemini API key for AI job summaries.
# Get a free key at https://aistudio.google.com/apikey — leave blank to disable summaries.
GEMINI_API_KEY=

# Optional: set to true to log notifications instead of sending them.
# DRY_RUN=true
